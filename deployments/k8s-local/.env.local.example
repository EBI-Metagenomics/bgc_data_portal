# ============================================================
# BGC Data Portal — local dev secrets template
# ============================================================
# WARNING: This file is a template. The real .env.local is
#          gitignored and must NEVER be committed to source control.
#
# First-time setup:
#   cp deployments/k8s-local/.env.local.example deployments/k8s-local/.env.local
#   # Edit .env.local — the defaults below work as-is for local dev.
#
# To create/update the Kubernetes Secret from this file:
#   make create-local-secrets
#
# Alternatively, run manually:
#   kubectl create secret generic bgc-data-portal-secret \
#     --from-env-file=deployments/k8s-local/.env.local \
#     -n bgc-local --dry-run=client -o yaml | kubectl apply -f -
# ============================================================

# ── Django ───────────────────────────────────────────────────
# A random string used for cryptographic signing.
# The default below is safe for local dev only.
# MUST be changed to a strong random value in dev/prod environments.
DJANGO_SECRET_KEY=dev-secret-key-change-me-not-for-production

# API token for admin endpoints (e.g. package ingestion).
# Used in Authorization: Token <value> headers.
# Keep a short memorable value for local dev.
ADMIN_API_TOKEN=local-admin-token

# Token for project-level user access.
# Used by automated pipelines that interact with the API.
PROJECT_USER_TOKEN=local-project-token

# ── Database ─────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB below.
# Host must be "postgres" (the k8s Service name in the bgc-local namespace).
DATABASE_URL=postgres://bgc_dp_pg_user:localpassword@postgres:5432/mgnify_bgcs

# ── PostgreSQL ───────────────────────────────────────────────
# Consumed directly by the postgres StatefulSet via envFrom.
# If you change these, update DATABASE_URL above to match.
POSTGRES_USER=bgc_dp_pg_user
POSTGRES_PASSWORD=localpassword
POSTGRES_DB=mgnify_bgcs

# ── Celery ───────────────────────────────────────────────────
# RabbitMQ broker — "rabbitmq" is the k8s Service name.
# guest/guest is the default RabbitMQ account (only accessible within the cluster).
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672/

# Redis result backend — "redis" is the k8s Service name.
# DB 0 is used for task results.
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Redis cache ──────────────────────────────────────────────
# DB 1 is used for Django's cache framework to avoid collisions with Celery (DB 0).
DJANGO_CACHE_BACKEND=redis://redis:6379/1

# ── Notes ────────────────────────────────────────────────────
# ML-intensive management commands (backfill_protein_embeddings, etc.) require
# torch/esm packages that are NOT in the dev image (Dockerfile.dev).
# To run those commands locally, use the full production image:
#   docker run --rm -it --env-file deployments/k8s-local/.env.local \
#     quay.io/microbiome-informatics/bgc_dp_web_site:latest \
#     python manage.py backfill_protein_embeddings
