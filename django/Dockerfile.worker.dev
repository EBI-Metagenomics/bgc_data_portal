FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc build-essential python3-dev libffi-dev libssl-dev git \
    libxrender1 libxext6 libsm6 \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# ── Layer A: heavy ML packages (rarely change → maximise cache) ─────────────
COPY requirements-ml.txt .
RUN pip install --upgrade pip && pip install -r requirements-ml.txt

# ── Layer B: remaining deps (worker + dev extras) ────────────────────────────
COPY requirements-web.txt requirements-worker.txt requirements-dev.txt ./
RUN pip install --no-cache-dir -r requirements-worker.txt -r requirements-dev.txt

# ── Layer C: application code (changes often) ───────────────────────────────
COPY . .

# watchmedo restarts Celery automatically when Skaffold syncs .py files.
CMD ["watchmedo", "auto-restart", "--directory=/app", "--pattern=*.py", "--recursive", "--", \
     "celery", "-A", "bgc_data_portal.celery", "worker", "--loglevel=info"]
