FROM python:3.10-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc build-essential python3-dev libffi-dev libssl-dev git \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements-web.txt requirements-dev.txt ./
RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements-web.txt -r requirements-dev.txt

COPY . .

EXPOSE 8000

# Django runserver auto-reloads on file changes synced by Skaffold.
# For Celery, the 06-celery-deployment.yaml overrides this CMD with watchmedo.
CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]
